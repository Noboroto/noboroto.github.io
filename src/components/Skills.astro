---
import skillsData from '../data/skills.json';

const levelColors: Record<string, string> = {
  advanced: 'bg-green-500/10 text-green-600 dark:text-green-400 border-green-500/20',
  intermediate: 'bg-blue-500/10 text-blue-600 dark:text-blue-400 border-blue-500/20',
  beginner: 'bg-amber-500/10 text-amber-600 dark:text-amber-400 border-amber-500/20',
};
---

<section id="skills" class="py-20">
  <div class="container mx-auto px-4 max-w-5xl">
    <h2 class="text-2xl sm:text-3xl font-bold mb-8 sm:mb-12 text-center">Tech Stack</h2>
    <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-8">
      {
        skillsData.categories.map((cat) => (
          <div>
            <h3 class="text-lg font-semibold mb-4 text-slate-700 dark:text-slate-300">
              {cat.name}
            </h3>
            <div class="flex flex-wrap gap-2">
              {cat.skills.map((skill) => (
                <span
                  class={`px-3 py-1.5 text-sm rounded-lg border ${levelColors[skill.level] || levelColors.intermediate}`}
                >
                  {skill.name}
                </span>
              ))}
            </div>
          </div>
        ))
      }
    </div>

    <div class="flex justify-center gap-6 mt-8 text-xs text-slate-500">
      <span class="flex items-center gap-1"
        ><span class="w-2 h-2 rounded-full bg-green-500"></span> Advanced</span
      >
      <span class="flex items-center gap-1"
        ><span class="w-2 h-2 rounded-full bg-blue-500"></span> Intermediate</span
      >
      <span class="flex items-center gap-1"
        ><span class="w-2 h-2 rounded-full bg-amber-500"></span> Learning</span
      >
    </div>
  </div>
</section>
