---
import SocialLinks from './SocialLinks.astro';
import profile from '../data/profile.json';
---

<section id="contact" class="py-20 bg-slate-50 dark:bg-slate-800/50">
  <div class="container mx-auto px-4 max-w-2xl text-center">
    <h2 class="text-2xl sm:text-3xl font-bold mb-4">Get In Touch</h2>
    <p class="text-lg text-slate-600 dark:text-slate-400 mb-8">
      Interested in collaborating or have a question? Feel free to reach out.
    </p>

    <a
      href={`mailto:${profile.email}`}
      class="inline-block px-8 py-3 bg-primary-500 text-white rounded-lg hover:bg-primary-600 transition-colors font-medium text-lg mb-8"
    >
      Say Hello
    </a>

    <SocialLinks class="justify-center mb-6" iconSize="w-6 h-6" />

    <p class="text-sm text-slate-400">{profile.email}</p>
  </div>
</section>
