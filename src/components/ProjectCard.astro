---
import type { RepoData } from '../lib/types';
import { getRepoLanguages } from '../lib/categorize';

interface Props {
  repo: RepoData;
  featured?: boolean;
}

const { repo, featured = false } = Astro.props;
const title = repo.displayName || repo.name;
const desc = repo.displayDescription || repo.description || 'No description available';

const langColors: Record<string, string> = {
  Python: 'bg-blue-500',
  TypeScript: 'bg-blue-600',
  JavaScript: 'bg-yellow-400',
  'C#': 'bg-green-600',
  'C++': 'bg-pink-600',
  Java: 'bg-red-500',
  Dart: 'bg-cyan-500',
  HTML: 'bg-orange-500',
  TeX: 'bg-teal-500',
  Kotlin: 'bg-purple-500',
  CSS: 'bg-indigo-500',
  Shell: 'bg-emerald-500',
  PLpgSQL: 'bg-sky-500',
  TSQL: 'bg-sky-600',
  Prolog: 'bg-amber-500',
  Pascal: 'bg-lime-600',
  Assembly: 'bg-rose-500',
};

const repoLangs = getRepoLanguages(repo);
const updatedYear = new Date(repo.updatedAt).getFullYear();
---

<article
  class={`group rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 hover:shadow-lg hover:border-primary-500/50 transition-all duration-200 ${featured ? 'p-6' : 'p-4'}`}
  data-name={repo.name.toLowerCase()}
  data-description={desc.toLowerCase()}
  data-tier={repo.tier}
  data-domains={repo.domain.join(',')}
  data-language={repoLangs.map((l) => l.toLowerCase()).join(',')}
  data-stars={repo.stars}
  data-updated={repo.updatedAt}
>
  <div class="flex items-center justify-between mb-3">
    <div class="flex items-center gap-2 flex-wrap">
      {repoLangs.length > 0 ? repoLangs.map((lang) => (
        <span class="flex items-center gap-1">
          <span class={`inline-block w-3 h-3 rounded-full ${langColors[lang] || 'bg-slate-400'}`} />
          <span class="text-xs text-slate-500 dark:text-slate-400">{lang}</span>
        </span>
      )) : (
        <span class="flex items-center gap-1">
          <span class="inline-block w-3 h-3 rounded-full bg-slate-400" />
          <span class="text-xs text-slate-500 dark:text-slate-400">Other</span>
        </span>
      )}
      {repo.isFork && <span class="text-xs text-slate-400 italic">fork</span>}
      {repo.private && (
        <span class="text-xs px-1.5 py-0.5 bg-amber-100 dark:bg-amber-900/40 text-amber-700 dark:text-amber-400 rounded font-medium">
          private
        </span>
      )}
    </div>
    {
      repo.stars > 0 && (
        <span class="flex items-center gap-1 text-xs text-slate-500">
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
          {repo.stars}
        </span>
      )
    }
  </div>

  <h3
    class={`font-semibold mb-2 group-hover:text-primary-500 transition-colors ${featured ? 'text-xl' : 'text-lg'}`}
  >
    {title}
  </h3>

  <p
    class={`text-slate-600 dark:text-slate-400 mb-4 ${featured ? 'text-base' : 'text-sm'}`}
  >
    {desc}
  </p>

  {
    repo.topics.length > 0 && (
      <div class="flex flex-wrap gap-1 mb-4">
        {repo.topics.map((t) => (
          <span class="px-2 py-0.5 text-xs bg-slate-100 dark:bg-slate-700/50 text-slate-500 dark:text-slate-400 rounded-full">
            {t}
          </span>
        ))}
      </div>
    )
  }

  <div class="flex items-center gap-3 pt-2 border-t border-slate-100 dark:border-slate-700">
    <span class="text-xs text-slate-400">{updatedYear}</span>
    {!repo.private && (
      <a
        href={repo.url}
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-slate-500 hover:text-primary-500 transition-colors flex items-center gap-1"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path
            d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"
          ></path>
        </svg>
         Code
      </a>
    )}
    {
      repo.homepage && (
        <a
          href={repo.homepage}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-slate-500 hover:text-primary-500 transition-colors flex items-center gap-1"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
            />
          </svg>
           Live Demo
        </a>
      )
    }
  </div>
</article>
