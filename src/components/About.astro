---
import profile from '../data/profile.json';

interface Props {
  totalRepos: number;
  languages: string[];
  dockerizedCount: number;
}

const { totalRepos, languages, dockerizedCount } = Astro.props;
---

<section id="about" class="py-20">
  <div class="container mx-auto px-4 max-w-4xl">
    <h2 class="text-2xl sm:text-3xl font-bold mb-8 text-center">About Me</h2>
    <div class="grid md:grid-cols-2 gap-8 items-center">
      <div>
        <p class="text-lg text-slate-600 dark:text-slate-400 leading-relaxed mb-6">
          {profile.bio}
        </p>
        <div class="flex gap-8 text-sm text-slate-500 dark:text-slate-400">
          <div>
            <span class="font-bold text-2xl text-slate-900 dark:text-white">{totalRepos}</span>
            <br />Projects
          </div>
          <div>
            <span class="font-bold text-2xl text-slate-900 dark:text-white">{languages.length}</span>
            <br />Languages
          </div>
          <div>
            <span class="font-bold text-2xl text-slate-900 dark:text-white">{dockerizedCount}</span>
            <br />Dockerized
          </div>
        </div>
      </div>
      <div class="flex flex-wrap gap-2">
        {
          languages.slice(0, 12).map((lang) => (
            <span class="px-3 py-1 bg-slate-100 dark:bg-slate-800 rounded-full text-sm font-medium">
              {lang}
            </span>
          ))
        }
      </div>
    </div>

    <div class="mt-12">
      <h3 class="text-2xl font-bold mb-6 text-center">Education</h3>
      <div class="space-y-6">
        {
          profile.education.map((edu) => (
            <div class="flex gap-3 sm:gap-4 p-3 sm:p-4 rounded-lg bg-slate-50 dark:bg-slate-800/50">
              <div class="flex-shrink-0 w-10 h-10 sm:w-12 sm:h-12 bg-slate-200 dark:bg-slate-700 rounded-lg flex items-center justify-center">
                <svg class="w-6 h-6 text-slate-500 dark:text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" />
                </svg>
              </div>
              <div>
                <h4 class="font-semibold text-lg">{edu.institution}</h4>
                <p class="text-slate-600 dark:text-slate-400">{edu.degree}, {edu.field}</p>
                <p class="text-sm text-slate-500 dark:text-slate-500">{edu.startDate} – {edu.endDate}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
