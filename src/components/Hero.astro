---
import SocialLinks from './SocialLinks.astro';
import profile from '../data/profile.json';
---

<section id="hero" class="min-h-screen flex items-center justify-center pt-16">
  <div class="container mx-auto px-4 text-center">
    <img
      src={profile.avatarUrl}
      alt={profile.name}
      class="w-32 h-32 rounded-full mx-auto mb-6 border-4 border-primary-500/20"
      loading="eager"
    />
    <h1 class="text-3xl sm:text-4xl md:text-6xl font-bold mb-4">{profile.name}</h1>
    <p class="text-lg sm:text-xl md:text-2xl text-slate-600 dark:text-slate-400 mb-6 sm:mb-8 max-w-2xl mx-auto px-2">
      {profile.tagline}
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-8">
      <a
        href="#projects"
        class="px-6 py-3 bg-primary-500 text-white rounded-lg hover:bg-primary-600 transition-colors font-medium"
      >
        View Projects
      </a>
      <a
        href="#contact"
        class="px-6 py-3 border border-slate-300 dark:border-slate-600 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors font-medium"
      >
        Get in Touch
      </a>
    </div>
    <SocialLinks class="justify-center" />
  </div>
</section>
